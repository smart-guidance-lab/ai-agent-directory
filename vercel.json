{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*).xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/agent/:path", "destination": "/posts/:path.md" }
  ]
}
